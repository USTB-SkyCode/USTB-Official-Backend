# ================================================================
# 生产部署环境模板 (deploy/prod/.env)
# ================================================================
# 复制为 .env 后填入真实值。
# 密钥生成: python -c "import secrets; print(secrets.token_hex(32))"
# 已有合理默认的变量不在此列出，完整列表见 app/config.py

# ================================================================
# 核心安全密钥
# ================================================================
# SECRET_KEY                    Flask 会话签名密钥 (默认: 首启自动生成 | 必填: 否)
# FILE_DOWNLOAD_TOKEN_SECRET    文件下载令牌 HMAC 密钥 (默认: 首启自动生成 | 必填: 否)
# PGSQL_PASSWORD                PostgreSQL 密码 (默认: 首启自动生成 | 必填: 否)
# ── 三项均由 secrets-init 容器首次启动时自动生成并持久化
# ── 如需固定值（如迁移数据库），可在首启前填写
# ================================================================
SECRET_KEY=
FILE_DOWNLOAD_TOKEN_SECRET=
PGSQL_PASSWORD=

# ================================================================
# 应用环境
# ================================================================
# APP_ENV=production            环境标记 (默认: 空 | 必填: 否)
# APP_TIMEZONE=Asia/Shanghai    时区 (默认: Asia/Shanghai | 必填: 否)
# ================================================================
APP_ENV=production
APP_TIMEZONE=Asia/Shanghai

# ================================================================
# 安全域名白名单 — 四项通常填同一个域名
# ================================================================
# CORS_ALLOWED_ORIGINS=https://app.example.com    CORS 允许来源，逗号分隔 (默认: localhost | 必填: 是)
# OAUTH_ALLOWED_REDIRECT_HOSTS=app.example.com    OAuth 回调允许 host (默认: localhost | 必填: 是)
# APP_ALLOWED_RETURN_HOSTS=app.example.com         登录跳转允许 host (默认: localhost | 必填: 是)
# TRUSTED_HOSTS=app.example.com                    可信 Host 头白名单 (默认: localhost | 必填: 是)
# ================================================================
CORS_ALLOWED_ORIGINS=
OAUTH_ALLOWED_REDIRECT_HOSTS=
APP_ALLOWED_RETURN_HOSTS=
TRUSTED_HOSTS=

# ================================================================
# MCA 资源
# ================================================================
# MCA_BASE_URL=/resource/mca/ustb       路由前缀，Caddy + 前端运行时共用 (默认: 空 | 必填: 是)
#   Caddy 去掉此前缀后到 /data/mca 查找文件
# MCA_STORAGE_ROOT=/data/official/mca    宿主机绝对路径，Docker 只读挂载到 Caddy (默认: 无 | 必填: 是)
#   部署前须创建此目录（空目录即可）; 权限: 目录 755、文件 644
# ================================================================
MCA_BASE_URL=
MCA_STORAGE_ROOT=

# ================================================================
# 前端运行时 (→ /config.js → window.APP_CONFIG)
# ================================================================
# API_BASE_URL=https://api.example.com        后端 API 入口 (默认: 空 | 必填: 是)
# AUTH_BASE_URL=https://api.example.com        认证入口 (默认: 空 | 必填: 是)
# APP_BASE_URL=https://app.example.com         前端主入口 (默认: 空 | 必填: 是)
# SKIN_API_BASE_URL=https://skin.example.com   皮肤服务 API (默认: 空 | 必填: 是)
# ================================================================
API_BASE_URL=
AUTH_BASE_URL=
APP_BASE_URL=
SKIN_API_BASE_URL=

# ================================================================
# Caddy 入口域名
# ================================================================
# APP_SITE_HOST=app.example.com    前端域名，Traefik → Caddy (默认: 无 | 必填: 是)
# API_SITE_HOST=api.example.com    API 域名，Traefik → Caddy (默认: 无 | 必填: 是)
# ================================================================
APP_SITE_HOST=
API_SITE_HOST=

# ================================================================
# OAuth: GitHub
# ================================================================
# GITHUB_CLIENT_ID=                                                  (默认: 空 | 需要时填)
# GITHUB_CLIENT_SECRET=                                              (默认: 空 | 需要时填)
# GITHUB_REDIRECT_URI=https://api.example.com/auth/github/callback   (默认: 空 | 需要时填)
# ================================================================
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=

# ================================================================
# OAuth: MUA
# ================================================================
# MUA_CLIENT_ID=        (默认: 空 | 需要时填)
# MUA_CLIENT_SECRET=    (默认: 空 | 需要时填)
# MUA_REDIRECT_URI=     (默认: 空 | 需要时填)
# ================================================================
MUA_CLIENT_ID=
MUA_CLIENT_SECRET=
MUA_REDIRECT_URI=

# ================================================================
# OAuth: USTB Blessing Skin
# ================================================================
# USTB_CLIENT_ID=                            (默认: 空 | 需要时填)
# USTB_CLIENT_SECRET=                        (默认: 空 | 需要时填)
# USTB_BASE_URL=https://skin.ustb.world      实例地址 (默认: 空 | 需要时填)
# USTB_REDIRECT_URI=                         (默认: 空 | 需要时填)
# ================================================================
USTB_CLIENT_ID=
USTB_CLIENT_SECRET=
USTB_BASE_URL=
USTB_REDIRECT_URI=

# ================================================================
# 可选: Bilibili 抓取凭据
# ================================================================
# BILIBILI_SESSDATA=       SESSDATA cookie (默认: 空 | 否)
# BILIBILI_JCT=            bili_jct CSRF token (默认: 空 | 否)
# BILIBILI_DEDEUSERID=     用户 ID (默认: 空 | 否)
# BILIBILI_BUVID3=         buvid3 设备指纹 (默认: 空 | 否)
# ================================================================
BILIBILI_SESSDATA=
BILIBILI_JCT=
BILIBILI_DEDEUSERID=
BILIBILI_BUVID3=

# ================================================================
# 可选: RSS
# ================================================================
# RSS_SOURCE_URL=https://...    RSS 源地址 (默认: 空 | 否)
# ================================================================
RSS_SOURCE_URL=

# ================================================================
# 选填: 应用行为
# ================================================================
# STRICT_ENV=true                            严格环境校验 (默认: true | 否)
# SESSION_LIFETIME=3600                      会话有效期秒数 (默认: 3600 | 否)
# SECURE_COOKIES=true                        HTTPS Cookie (默认: true | 否)
# SESSION_DEBUG=false                        Session 调试日志 (默认: false | 否)
# OAUTH_ALLOW_HTTP_LOCALHOST=false           允许 OAuth 回调到 http localhost (默认: true | 否)
# APP_ALLOW_HTTP_LOCALHOST=false             允许登录回跳到 http localhost (默认: true | 否)
# DEFAULT_LOGIN_SUCCESS_URL=/home            登录成功默认跳转路径 (默认: /home | 否)
# ================================================================
STRICT_ENV=
SESSION_LIFETIME=
SECURE_COOKIES=
SESSION_DEBUG=
OAUTH_ALLOW_HTTP_LOCALHOST=
APP_ALLOW_HTTP_LOCALHOST=
DEFAULT_LOGIN_SUCCESS_URL=

# ================================================================
# 选填: 文件下载与资源路径
# ================================================================
# FILE_DOWNLOAD_TOKEN_SALT=file-download-token  下载令牌盐 (默认: file-download-token | 否)
# FILE_DOWNLOAD_TOKEN_TTL=300                   下载令牌有效期秒数 (默认: 300 | 否)
# FILE_DOWNLOAD_BASE_PATH=/downloads            下载 URL 前缀 (默认: /downloads | 否)
# MCA_ACCESS_LEVEL=public                       MCA 入口权限级别 (默认: public | 否)
# 资源包产物固定发布在 /packs/<目录>/{compiled,assets}，目录由 index.json 注册
# SKIN_BASE_URL=/assets/skin                   皮肤静态资源兜底路径 (默认: /assets/skin | 否)
# ================================================================
FILE_DOWNLOAD_TOKEN_SALT=
FILE_DOWNLOAD_TOKEN_TTL=
FILE_DOWNLOAD_BASE_PATH=
MCA_ACCESS_LEVEL=
SKIN_BASE_URL=

# ================================================================
# 选填: 同源代理与请求限制
# ================================================================
# SAME_ORIGIN_ASSET_PROXY_PATH=/skin-origin-proxy                   同源代理入口 (默认: /skin-origin-proxy | 否)
# ASSET_PROXY_ALLOWED_HOSTS=skin.ustb.world,...                     同源代理白名单 (默认: 内置列表 | 否)
# ASSET_PROXY_TIMEOUT=10                                            同源代理超时秒数 (默认: 10 | 否)
# PROXY_FIX_X_FOR=1                                                 ProxyFix X-Forwarded-For 信任层数 (默认: 1 | 否)
# PROXY_FIX_X_PROTO=1                                               ProxyFix X-Forwarded-Proto 信任层数 (默认: 1 | 否)
# PROXY_FIX_X_HOST=1                                                ProxyFix X-Forwarded-Host 信任层数 (默认: 1 | 否)
# MAX_CONTENT_LENGTH=1048576                                        请求体最大字节数 (默认: 1048576 | 否)
# WTF_CSRF_SSL_STRICT=false                                         CSRF SSL 严格模式 (默认: false | 否)
# ================================================================
SAME_ORIGIN_ASSET_PROXY_PATH=
ASSET_PROXY_ALLOWED_HOSTS=
ASSET_PROXY_TIMEOUT=
PROXY_FIX_X_FOR=
PROXY_FIX_X_PROTO=
PROXY_FIX_X_HOST=
MAX_CONTENT_LENGTH=
WTF_CSRF_SSL_STRICT=

# ================================================================
# 选填: RSS 刷新
# ================================================================
# RSS_REFRESH_ENABLED=true                   定期刷新 RSS (默认: true | 否)
# RSS_REFRESH_INTERVAL=1800                 RSS 刷新间隔秒数 (默认: 1800 | 否)
# ================================================================
RSS_REFRESH_ENABLED=
RSS_REFRESH_INTERVAL=

# ================================================================
# 选填: Compose / 入口覆盖
# ================================================================
# COMPOSE_FILE=docker-compose.yml                                锁定 prod 主编排文件，避免 docker-compose.override.yml 被默认自动加载
#   不要依赖默认 override；如需额外入口层或本机 ACME，请显式修改 compose / Caddy 配置
# FILE_DATA_HOST_PATH=../../file-data                            宿主机 file-data 目录 (默认: 相对 compose 文件的 ../../file-data | 否)
# BACKEND_BUILD_CONTEXT=../..                                    后端镜像构建上下文 (默认: ../.. | 否)
# FRONTEND_BUILD_CONTEXT=https://github.com/...#main             前端构建上下文 (默认: 官方前端仓库 main | 否)
# FRONTEND_RESOURCEPACK_HOST_PATH=/data/official/front-resourcepack
#   正式环境里 world/resource/resourcepack 的实际宿主机目录；deployment-local 的 *.pack.json 和对应资源目录放这里
#   resource-builder 容器产物写入 frontend_packs volume，前端容器自动挂载
# BACKEND_UPSTREAM=http://backend:5000                           Caddy 回源后端地址 (默认: http://backend:5000 | 否)
# FRONTEND_UPSTREAM=http://frontend:80                           Caddy 回源前端地址 (默认: http://frontend:80 | 否)
# ================================================================
COMPOSE_FILE=docker-compose.yml
FILE_DATA_HOST_PATH=
BACKEND_BUILD_CONTEXT=
FRONTEND_BUILD_CONTEXT=
FRONTEND_RESOURCEPACK_HOST_PATH=
BACKEND_UPSTREAM=
FRONTEND_UPSTREAM=

# ================================================================
# 说明: 以下变量在 deploy/prod/docker-compose.yml 中已固定注入，写在此处也不会生效
# FLASK_HOST, FLASK_PORT, PGSQL_HOST, PGSQL_PORT, PGSQL_DB, PGSQL_USER, REDIS_URL, FILE_STORAGE_ROOT
# ================================================================

# ================================================================