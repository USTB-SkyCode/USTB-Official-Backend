(common_headers) {
	header {
		X-Content-Type-Options nosniff
		X-Frame-Options SAMEORIGIN
		Referrer-Policy strict-origin-when-cross-origin
	}
}

(cross_origin_isolation_headers) {
	header {
		Cross-Origin-Opener-Policy same-origin
		Cross-Origin-Embedder-Policy require-corp
		Cross-Origin-Resource-Policy same-origin
	}
}

http://{$API_SITE_HOST} {
	import common_headers
	reverse_proxy {$BACKEND_UPSTREAM}
}

http://{$APP_SITE_HOST} {
	import common_headers
	import cross_origin_isolation_headers

	@deny_config_template path /config.template.js
	@deny_vite_dev_paths path /@vite/* /@id/* /src/* /node_modules/* /__x00__*
	@downloads path /downloads/*
	@backend path /api* /auth* /config.js /skin-origin-proxy* /diagnostics*
	@mca path {$MCA_BASE_URL}/*
	@immutable_assets path /assets/* /packs/* /model/* /basic/*
	@resource_assets path /resource/*
	@file_like_requests path_regexp file_like .+\.[A-Za-z0-9]+$

	route {
		handle @deny_config_template {
			respond "Not Found" 404
		}

		handle @deny_vite_dev_paths {
			respond "Not Found" 404
		}

		handle @downloads {
			forward_auth {$BACKEND_UPSTREAM} {
				uri /api/file-downloads/authorize
			}
			uri strip_prefix /downloads
			root * /data/file-data
			header Content-Disposition "attachment"
			file_server
		}

		handle @backend {
			reverse_proxy {$BACKEND_UPSTREAM}
		}

		handle @mca {
			forward_auth {$BACKEND_UPSTREAM} {
				uri /api/mca-downloads/authorize
			}
			route {
				uri strip_prefix {$MCA_BASE_URL}
				root * /data/mca
				header Cache-Control "no-cache, must-revalidate, max-age=0"
				file_server
			}
		}

		handle @immutable_assets {
			header Cache-Control "public, max-age=31536000, immutable"
			reverse_proxy {$FRONTEND_UPSTREAM}
		}

		handle @resource_assets {
			header Cache-Control "public, max-age=2592000, immutable"
			reverse_proxy {$FRONTEND_UPSTREAM}
		}

		handle @file_like_requests {
			reverse_proxy {$FRONTEND_UPSTREAM}
		}

		handle {
			header Cache-Control "no-store"
			reverse_proxy {$FRONTEND_UPSTREAM}
		}
	}
}