# Prodlike 环境模板
#
# 使用方法:
# 1. 以 deploy/prod/env.example 为基础填写完整应用环境变量。
# 2. 保存为 deploy/dev/prodlike/.env。
# 3. 补充或覆盖以下 prodlike 专用值。

APP_ENV=production
STRICT_ENV=true

# 入口域名 — 替换为你的开发域名或 localhost
APP_SITE_HOST=
API_SITE_HOST=

# 密钥 — 留空则 secrets-init 自动生成随机值
SECRET_KEY=
FILE_DOWNLOAD_TOKEN_SECRET=
PGSQL_PASSWORD=

# MCA（可选）
MCA_BASE_URL=
MCA_STORAGE_ROOT=